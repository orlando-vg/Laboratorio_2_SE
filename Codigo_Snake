#include <stdint.h>
#include <stdlib.h>
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "driver/gpio.h"

// Filas
int filas[6] = {12,14,27,26,25,33};

// Columnas
int rojo[6]  = {5,19,23,17,15,4};
int verde[6] = {13,18,21,2,22,16};

// Botones 
#define UP    32
#define DOWN  34
#define LEFT  35
#define RIGHT 36

int R[6][6];
int G[6][6];

int sx[36], sy[36];
int len;
int dir;

int fx, fy;


TickType_t lastMove = 0;
const TickType_t speed = pdMS_TO_TICKS(500);

void clear(){
    for(int i=0;i<6;i++)
        for(int j=0;j<6;j++){
            R[i][j]=0;
            G[i][j]=0;
        }
}
 
void draw(){
    for(int f=0; f<6; f++){

        for(int i=0;i<6;i++){
            gpio_set_level(filas[i],0);
            gpio_set_level(rojo[i],0);
            gpio_set_level(verde[i],0);
        }

        for(int c=0;c<6;c++){
            gpio_set_level(rojo[c], R[f][c]);
            gpio_set_level(verde[c], G[f][c]);
        }

        gpio_set_level(filas[f],1);

        vTaskDelay(pdMS_TO_TICKS(2));
    }
}

// Comida(Manzanas)
void food(){
    int ok;
    do{
        ok=1;
        fx = rand()%6;
        fy = rand()%6;

        for(int i=0;i<len;i++){
            if(sx[i]==fx && sy[i]==fy) ok=0;
        }
    }while(!ok);
}


void input(){
    if(gpio_get_level(UP)==0 && dir!=2) dir=0;
    if(gpio_get_level(RIGHT)==0 && dir!=3) dir=1;
    if(gpio_get_level(DOWN)==0 && dir!=0) dir=2;
    if(gpio_get_level(LEFT)==0 && dir!=1) dir=3;
}

 
int update(){

    int nx=sx[0], ny=sy[0];

    if(dir==0) nx--;
    if(dir==1) ny++;
    if(dir==2) nx++;
    if(dir==3) ny--;

    if(nx<0||nx>=6||ny<0||ny>=6) return 0;

    for(int i=0;i<len;i++){
        if(sx[i]==nx && sy[i]==ny) return 0;
    }

    for(int i=len;i>0;i--){
        sx[i]=sx[i-1];
        sy[i]=sy[i-1];
    }

    sx[0]=nx;
    sy[0]=ny;

    if(nx==fx && ny==fy){
        len++;
        food();
    }

    return 1;
}

 
void build(){
    clear();

    for(int i=0;i<len;i++){
        R[sx[i]][sy[i]]=1;
    }

    G[fx][fy]=1;
}

//Perder
void lose(){

    for(int k=0;k<2;k++){

        // Pantalla roja cuando se pierde 
        for(int i=0;i<6;i++)
            for(int j=0;j<6;j++){
                R[i][j]=1;
                G[i][j]=0;
            }

        for(int t=0;t<800;t++) draw(); 

        clear();

        for(int t=0;t<600;t++) draw(); 
    }
}


void reset(){
    len=3;
    dir=1;

    sx[0]=2; sy[0]=2;
    sx[1]=2; sy[1]=1;
    sx[2]=2; sy[2]=0;

    food();
}


void app_main(){

    for(int i=0;i<6;i++){
        gpio_set_direction(filas[i],GPIO_MODE_OUTPUT);
        gpio_set_direction(rojo[i],GPIO_MODE_OUTPUT);
        gpio_set_direction(verde[i],GPIO_MODE_OUTPUT);
    }

    gpio_set_direction(UP,GPIO_MODE_INPUT);
    gpio_set_direction(DOWN,GPIO_MODE_INPUT);
    gpio_set_direction(LEFT,GPIO_MODE_INPUT);
    gpio_set_direction(RIGHT,GPIO_MODE_INPUT);

    gpio_set_pull_mode(UP,GPIO_PULLUP_ONLY);
    gpio_set_pull_mode(DOWN,GPIO_PULLUP_ONLY);
    gpio_set_pull_mode(LEFT,GPIO_PULLUP_ONLY);
    gpio_set_pull_mode(RIGHT,GPIO_PULLUP_ONLY);

    reset();

    while(1){

        draw();
        input();

        if(xTaskGetTickCount() - lastMove > speed){

            if(!update()){
                lose();
                reset();
            }

            build();
            lastMove = xTaskGetTickCount();
        }
    }
}
